<circle
cx="0"
cy="0"
r="34"
fill="#FFFFFF"/>

<circle
cx="0"
cy="0"
r="16"
fill="#FF0000"/>

<path
fill="#FFD700"
d="
M0 -52
L7 -34
L24 -40
L34 -24
L52 -18
L40 0
L52 18
L34 24
L24 40
L7 34
L0 52
L-7 34
L-24 40
L-34 24
L-52 18
L-40 0
